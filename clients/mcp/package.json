{
  "name": "@budgetary/mcp",
  "version": "0.6.1",
  "description": "Model Context Protocol server for Budgetary: a portable pre-flight token-spend estimate tool for any MCP-capable host.",
  "mcpName": "io.github.thriftell/budgetary",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thriftell/budgetary-clients.git",
    "directory": "clients/mcp"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "bin": {
    "budgetary-mcp": "bin/budgetary-mcp.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./actuals": {
      "types": "./dist/actuals.d.ts",
      "import": "./dist/actuals.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node scripts/collect-third-party-licenses.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "biome lint ."
  },
  "dependencies": {
    "@budgetary/sdk": "workspace:*"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
