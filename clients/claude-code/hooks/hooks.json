{
  "description": "Submit realized token totals to Budgetary when a Claude Code session ends, so future estimates calibrate.",
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "BUDGETARY_API_KEY=\"${user_config.api_key}\" npx -y @budgetary/mcp@0.2.4 on-session-end",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
