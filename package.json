{
  "name": "budgetary-clients",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Budgetary clients (SDKs and editor plugins).",
  "license": "Apache-2.0",
  "scripts": {
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "changeset publish"
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
