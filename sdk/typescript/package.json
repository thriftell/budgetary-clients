{
  "name": "@budgetary/sdk",
  "version": "0.0.0",
  "description": "TypeScript SDK for the Budgetary API.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type: 'commonjs'}))\"",
    "test": "vitest run",
    "lint": "echo \"@budgetary/sdk: lint placeholder\""
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.7.0",
    "msw": "^2.6.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
