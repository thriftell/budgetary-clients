{
  "name": "@budgetary/sdk",
  "version": "0.3.2",
  "description": "TypeScript SDK for the Budgetary API.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thriftell/budgetary-clients.git",
    "directory": "sdk/typescript"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type: 'commonjs'}))\"",
    "prepare": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "biome lint ."
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.7.0",
    "msw": "^2.6.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
